Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===",
     " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", 
    " ", "===", " ", "===", " ", "===", " ", "===", " ", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"02", ":", 
    RowBox[{
     RowBox[{"Matrix", " ", "Logic"}], "-", 
     RowBox[{"DYNAMIC", " ", "AI", " ", "EXECUTION"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===",
     " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", 
    " ", "===", " ", "===", " ", "===", " ", "===", " ", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing Dynamic ACH Engine ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "<<", "\"\</Users/Western/Desktop/ThesisCode/Core_API_Functions.wl\>\""}],
     ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "IMPORT"}]}], " ", "VAULT", " ", 
      RowBox[{"DATA", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "evidencePath", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_vault.md\>\""}\
], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "hypothesesPath", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/target_hypotheses.md\>\
\""}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"evidenceList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{"evidencePath", ",", "\"\<Text\>\""}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], "]"}], ",", "\"\<\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"hypothesesList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{"hypothesesPath", ",", "\"\<Text\>\""}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], "]"}], ",", "\"\<\>\""}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"numRows", "=", 
     RowBox[{"Length", "[", "evidenceList", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numCols", "=", 
     RowBox[{"Length", "[", "hypothesesList", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Target Hypotheses Loaded: \>\"", ",", "numCols"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Evidence Items Loaded: \>\"", ",", "numRows"}], "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "THE"}]}], " ", "GEMINI", " ", 
      RowBox[{"PROMPT", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Constructing the LLM Grading Prompt ---\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"systemInstructions", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst executing the \
Analysis of Competing Hypotheses (ACH).\\nI will provide a list of exactly \>\
\"", "<>", 
      RowBox[{"ToString", "[", "numRows", "]"}], 
      "<>", "\"\< Evidence items and exactly \>\"", "<>", 
      RowBox[{"ToString", "[", "numCols", "]"}], 
      "<>", "\"\< Hypotheses.\\nYou must score every piece of evidence \
against every hypothesis.\\nUse ONLY the following exact strings: \\\"C\\\" \
(Consistent), \\\"I\\\" (Inconsistent), \\\"II\\\" (Highly Inconsistent), \
\\\"N\\\" (Neutral), \\\"NA\\\" (Not Applicable).\\n\\nTo prevent repetitive \
patterns, you must output your response STRICTLY as a JSON Object (key-value \
pairs).\\nThe keys MUST be the numeric ID of the Evidence (1 through \>\"", "<>", 
      RowBox[{"ToString", "[", "numRows", "]"}], 
      "<>", "\"\<).\\nThe values MUST be an array of exactly \>\"", "<>", 
      RowBox[{"ToString", "[", "numCols", "]"}], 
      "<>", "\"\< scores corresponding to the Hypotheses in order.\\nDo not \
include markdown blocks, explanations, or any other text.\\nOutput ONLY the \
raw JSON object like this: {\\\"1\\\": [\\\"C\\\", \\\"I\\\", \\\"N\\\", \
\\\"C\\\"], \\\"2\\\": [\\\"II\\\", \\\"C\\\", \\\"C\\\", \
\\\"N\\\"]}\>\""}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"evidenceString", "=", 
     RowBox[{"\"\<EVIDENCE LIST:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"evidenceList", ",", "\"\<\\n\>\""}], "]"}], "]"}]}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"hypothesesString", "=", 
     RowBox[{"\"\<HYPOTHESES LIST:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"hypothesesList", ",", "\"\<\\n\>\""}], "]"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"fullPrompt", "=", 
     RowBox[{
     "systemInstructions", "<>", "\"\<\\n\\n\>\"", "<>", "evidenceString", 
      "<>", "\"\<\\n\\n\>\"", "<>", "hypothesesString"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXECUTE"}]}], " ", "API", " ", 
      RowBox[{"CALL", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Sending Matrix to Gemini API ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"rawResponse", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"fullPrompt", ",", "0.2"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Parse"}]}], " ", "JSON", " ", 
      RowBox[{"Response", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanJSON", "=", 
     RowBox[{"StringTrim", "[", "rawResponse", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleanJSON", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"cleanJSON", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"CRITICAL", " ", 
     RowBox[{"FIX", ":", 
      RowBox[{
      "Use", " ", "\"\<RawJSON\>\"", " ", "to", " ", "guarantee", " ", "an", " ",
        "Association", " ", "object"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"jsonAssoc", "=", 
     RowBox[{"ImportString", "[", 
      RowBox[{"cleanJSON", ",", "\"\<RawJSON\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Fail", "-", 
     RowBox[{"safe", " ", "check"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"jsonAssoc", "===", "$Failed"}], "||", 
       RowBox[{"!", 
        RowBox[{"AssociationQ", "[", "jsonAssoc", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
       "Print", 
        "[", "\"\<[ERROR] Failed to parse JSON object. Response was truncated \
or malformed.\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Raw string length: \>\"", ",", 
         RowBox[{"StringLength", "[", "cleanJSON", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}], ";"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Rebuild", " ", "2", "D", " ", "Matrix", " ", "safely", " ", "and", " ", 
     "guarantee", " ", "rectangular", " ", "dimensions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aiMatrix", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"row", "=", 
           RowBox[{"Lookup", "[", 
            RowBox[{"jsonAssoc", ",", 
             RowBox[{"ToString", "[", "i", "]"}], ",", 
             RowBox[{"Table", "[", 
              RowBox[{"\"\<N\>\"", ",", 
               RowBox[{"{", "numCols", "}"}]}], "]"}]}], "]"}]}], "}"}], ",", 
         
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"ListQ", "[", "row", "]"}]}], ",", 
            RowBox[{"row", "=", 
             RowBox[{"{", "row", "}"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"PadRight", "[", 
           RowBox[{
            RowBox[{"Take", "[", 
             RowBox[{"row", ",", 
              RowBox[{"UpTo", "[", "numCols", "]"}]}], "]"}], ",", "numCols", 
            ",", "\"\<N\>\""}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "numRows"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Checkmark] AI Matrix Scored! Dimensions: \>\"", ",", 
      RowBox[{"Dimensions", "[", "aiMatrix", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"--", 
        RowBox[{"-", "FORMAT"}]}], "&"}], " ", "EXPORT", " ", "MARKDOWN", " ", 
      RowBox[{"TABLE", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Formatting Markdown Table for Obsidian ---\>\"",
      "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Safely", " ", "stringify", " ", "the", " ", "headers"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"headerRow", "=", 
     RowBox[{"\"\<| Evidence | \>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{
         RowBox[{"ToString", "/@", "hypothesesList"}], ",", "\"\< | \>\""}], 
        "]"}], "]"}], "<>", "\"\< |\\n\>\""}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"separatorRow", "=", 
     RowBox[{"\"\<|---\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Table", "[", 
        RowBox[{"\"\<|---\>\"", ",", 
         RowBox[{"{", "numCols", "}"}]}], "]"}], "]"}], 
      "<>", "\"\<|\\n\>\""}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Safely", " ", "stringify", " ", "every", " ", "cell", " ", "in", " ", 
     "the", " ", "matrix"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dataRows", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<| \>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"evidenceList", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], "<>", "\"\< | \>\"", "<>", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"Riffle", "[", 
           RowBox[{
            RowBox[{"ToString", "/@", 
             RowBox[{"aiMatrix", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", "\"\< | \>\""}], "]"}], 
          "]"}], "<>", "\"\< |\\n\>\""}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "numRows"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"mdTable", "=", 
     RowBox[{"headerRow", "<>", "separatorRow", "<>", "dataRows"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/ai_scored_matrix.md\
\>\"", ",", "mdTable", ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/ai_scored_matrix.\
json\>\"", ",", "aiMatrix"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] DONE. Matrix exported as .md (for \
Obsidian) and .json (for Notebook 03).\>\"", "]"}], ";"}]}]}]], "Input",

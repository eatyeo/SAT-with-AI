  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Get", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], 
      "<>", "\"\<Core_API_Functions.wl\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing Dynamic ACH Engine ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Load", " ", "Vault", " ", "data"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"evidenceList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{
            RowBox[{"$vaultDir", "<>", "\"\<evidence_vault.md\>\""}], 
            ",", "\"\<Text\>\""}], "]"}], ",", "\"\<\\n\>\""}], "]"}], "]"}], 
       ",", "\"\<\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hypothesesList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{
            RowBox[{"$vaultDir", "<>", "\"\<target_hypotheses.md\>\""}], 
            ",", "\"\<Text\>\""}], "]"}], ",", "\"\<\\n\>\""}], "]"}], "]"}], 
       ",", "\"\<\>\""}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numRows", "=", 
     RowBox[{"Length", "[", "evidenceList", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numCols", "=", 
     RowBox[{"Length", "[", "hypothesesList", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Hypotheses loaded: \>\"", ",", "numCols"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Evidence items loaded: \>\"", ",", "numRows"}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "Shared"}]}], " ", "system", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"instructions", "--"}], "--"}], "--"}], "--"}], 
                 "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
          "--"}], "--"}], "--"}], "--"}], "--"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Constructing the LLM Grading Prompt ---\>\"", 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"systemInstructions", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst executing the \
Analysis \>\"", "<>", "\"\<of Competing Hypotheses (ACH).\\n\>\"", 
      "<>", "\"\<I will provide a list of Evidence items and exactly \>\"", "<>", 
      RowBox[{"ToString", "[", "numCols", "]"}], 
      "<>", "\"\< Hypotheses.\\n\>\"", 
      "<>", "\"\<You must score every piece of evidence against every \
hypothesis \>\"", "<>", "\"\<using ONLY these exact strings:\\n\>\"", 
      "<>", "\"\<  \\\"CC\\\" (Highly Consistent: very strong support for \
this hypothesis and not the others),\\n\>\"", 
      "<>", "\"\<  \\\"C\\\"  (Consistent: fits comfortably with this \
hypothesis),\\n\>\"", 
      "<>", "\"\<  \\\"N\\\"  (Neutral / Not Diagnostic: provides little or \
no help in judging this hypothesis),\\n\>\"", 
      "<>", "\"\<  \\\"I\\\"  (Inconsistent: tends to undercut this \
hypothesis, but could fit under some assumptions),\\n\>\"", 
      "<>", "\"\<  \\\"II\\\" (Highly Inconsistent: strongly contradicts this \
hypothesis under almost any reasonable assumption),\\n\>\"", 
      "<>", "\"\<  \\\"NA\\\" (Not Applicable: genuinely irrelevant to this \
hypothesis).\\n\\n\>\"", "<>", "\"\<USAGE RULES:\\n\>\"", 
      "<>", "\"\<- Use \\\"CC\\\" sparingly - only when evidence clearly and \
strongly favours ONE hypothesis over the others.\\n\>\"", 
      "<>", "\"\<- Use \\\"II\\\" when the evidence would almost never be \
seen if the hypothesis were true.\\n\>\"", 
      "<>", "\"\<- Use \\\"I\\\" for milder contradictions that depend on \
debatable assumptions.\\n\>\"", 
      "<>", "\"\<- Use \\\"N\\\" when evidence is background context or \
roughly as compatible with all hypotheses.\\n\>\"", 
      "<>", "\"\<- Use \\\"NA\\\" when evidence genuinely has no bearing on \
the hypothesis.\\n\\n\>\"", "<>", "\"\<HYPOTHESES LIST:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"hypothesesList", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      "<>", "\"\<\\n\\n\>\"", 
      "<>", "\"\<Output STRICTLY as a JSON Object (key-value pairs).\\n\>\"", 
      "<>", "\"\<Keys MUST be the numeric ID of the Evidence item as \
provided.\\n\>\"", "<>", "\"\<Values MUST be an array of exactly \>\"", "<>", 
      
      RowBox[{"ToString", "[", "numCols", "]"}], 
      "<>", "\"\< scores corresponding to the Hypotheses in order.\\n\>\"", 
      "<>", "\"\<Do not include markdown, explanations, or any other text.\\n\
\>\"", "<>", "\"\<Output ONLY the raw JSON object, for example:\\n\>\"", 
      "<>", "\"\<{\\\"1\\\": [\\\"C\\\", \\\"I\\\", \\\"N\\\"], \\\"2\\\": \
[\\\"II\\\", \\\"C\\\", \\\"C\\\"]}\>\""}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"--", "Batched"}]}], " ", "API", " ", "calls", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"10", " ", "rows", " ", "per", " ", "batch"}], ")"}],
                 "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
         "--"}], "--"}], "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Sending Matrix to Gemini API (Batched) ---\>\"",
      "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"batchSize", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numBatches", "=", 
     RowBox[{"Ceiling", "[", 
      RowBox[{"numRows", "/", "batchSize"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allBatchResults", "=", 
     RowBox[{"Association", "[", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "batchStart", ",", "batchEnd", ",", "batchEvidence", ",", 
          "batchEvidenceString", ",", "batchPrompt", ",", "batchResponse", ",",
           "batchClean", ",", "batchAssoc"}], "}"}], ",", 
        RowBox[{
         RowBox[{"batchStart", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "1"}], ")"}], "*", "batchSize"}], "+", "1"}]}],
          ";", "\[IndentingNewLine]", 
         RowBox[{"batchEnd", "=", 
          RowBox[{"Min", "[", 
           RowBox[{
            RowBox[{"b", "*", "batchSize"}], ",", "numRows"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"batchEvidence", "=", 
          RowBox[{"evidenceList", "[", 
           RowBox[{"[", 
            RowBox[{"batchStart", ";;", "batchEnd"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<--- Batch \>\"", "<>", 
           RowBox[{"ToString", "[", "b", "]"}], "<>", "\"\< of \>\"", "<>", 
           RowBox[{"ToString", "[", "numBatches", "]"}], 
           "<>", "\"\< (rows \>\"", "<>", 
           RowBox[{"ToString", "[", "batchStart", "]"}], "<>", "\"\<-\>\"", "<>", 
           RowBox[{"ToString", "[", "batchEnd", "]"}], 
           "<>", "\"\<) ---\>\""}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"batchEvidenceString", "=", 
          
          RowBox[{"\"\<EVIDENCE LIST (use the numeric ID as the JSON key):\\n\
\>\"", "<>", 
           RowBox[{"StringJoin", "[", 
            RowBox[{"MapIndexed", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"ToString", "[", 
                  RowBox[{
                   RowBox[{"#2", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "+", "batchStart", "-", 
                   "1"}], "]"}], "<>", "\"\<. \>\"", "<>", "#1", 
                 "<>", "\"\<\\n\>\""}], ")"}], "&"}], ",", "batchEvidence"}], 
             "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"batchPrompt", "=", 
          RowBox[{
          "systemInstructions", "<>", "\"\<\\n\\n\>\"", "<>", 
           "batchEvidenceString"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"batchResponse", "=", 
          RowBox[{"callGemini", "[", 
           RowBox[{"batchPrompt", ",", "0.2"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"batchClean", "=", 
          RowBox[{"StringTrim", "[", "batchResponse", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"batchClean", "=", 
          RowBox[{"StringReplace", "[", 
           RowBox[{"batchClean", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
              RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
              RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"batchAssoc", "=", 
          RowBox[{"ImportString", "[", 
           RowBox[{"batchClean", ",", "\"\<RawJSON\>\""}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"batchAssoc", "===", "$Failed"}], "||", 
            RowBox[{"!", 
             RowBox[{"AssociationQ", "[", "batchAssoc", "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{"\"\<[ERROR] Batch \>\"", "<>", 
              RowBox[{"ToString", "[", "b", "]"}], 
              "<>", "\"\< failed to parse. Response may be truncated.\>\""}], 
             "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{"\"\<Raw string length: \>\"", ",", 
              RowBox[{"StringLength", "[", "batchClean", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"allBatchResults", "=", 
          RowBox[{"Join", "[", 
           RowBox[{"allBatchResults", ",", "batchAssoc"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<\[Checkmark] Batch \>\"", "<>", 
           RowBox[{"ToString", "[", "b", "]"}], "<>", "\"\< processed.\>\""}],
           "]"}], ";"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"b", ",", "numBatches"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Build", " ", "2", "D", " ", "matrix"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"jsonAssoc", "=", "allBatchResults"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"aiMatrix", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"row", "=", 
           RowBox[{"Lookup", "[", 
            RowBox[{"jsonAssoc", ",", 
             RowBox[{"ToString", "[", "i", "]"}], ",", 
             RowBox[{"Table", "[", 
              RowBox[{"\"\<N\>\"", ",", 
               RowBox[{"{", "numCols", "}"}]}], "]"}]}], "]"}]}], "}"}], ",", 
         
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"ListQ", "[", "row", "]"}]}], ",", 
            RowBox[{"row", "=", 
             RowBox[{"{", "row", "}"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"PadRight", "[", 
           RowBox[{
            RowBox[{"Take", "[", 
             RowBox[{"row", ",", 
              RowBox[{"UpTo", "[", "numCols", "]"}]}], "]"}], ",", "numCols", 
            ",", "\"\<N\>\""}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "numRows"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Checkmark] AI Matrix Scored! Dimensions: \>\"", ",", 
      RowBox[{"Dimensions", "[", "aiMatrix", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Duplicate", " ", "hypothesis", " ", "check"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"colPairs", "=", 
     RowBox[{"Subsets", "[", 
      RowBox[{
       RowBox[{"Range", "[", "numCols", "]"}], ",", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"duplicateWarnings", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"colPairs", ",", 
       RowBox[{"Function", "[", 
        RowBox[{"pair", ",", 
         RowBox[{
          RowBox[{"HammingDistance", "[", 
           RowBox[{
            RowBox[{"aiMatrix", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"aiMatrix", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "]"}]}], "]"}], "<", 
          
          RowBox[{"Ceiling", "[", 
           RowBox[{"0.15", "*", "numRows"}], "]"}]}]}], "]"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"duplicateWarnings", "=!=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[WARNING] Near-identical hypothesis pairs: \>\"", ",", 
         "duplicateWarnings"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<Consider revising hypotheses in 01.5 before finalizing.\>\"",
         "]"}]}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"--", "Assumption"}]}], " ", "surfacing", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"pass", "--"}], "--"}], "--"}], "--"}], "--"}], 
                 "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
          "--"}], "--"}], "--"}], "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Running Assumption Audit Pass ---\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumptionPrompt", "=", 
     RowBox[{"\"\<You are an expert ACH analyst reviewing a completed scoring \
matrix.\\n\\n\>\"", 
      "<>", "\"\<For each evidence item, identify the key assumption driving \
any \>\"", 
      "<>", "\"\<non-obvious rating in one sentence. Write \\\"None\\\" when \
no \>\"", "<>", "\"\<contested assumption was needed.\\n\\n\>\"", 
      "<>", "\"\<Output ONLY as a JSON object. Keys are evidence IDs (1 \
through \>\"", "<>", 
      RowBox[{"ToString", "[", "numRows", "]"}], 
      "<>", "\"\<). Values are objects with hypothesis labels \>\"", 
      "<>", "\"\<as keys and the assumption string (or \\\"None\\\") as \
values.\\n\\n\>\"", "<>", "\"\<HYPOTHESES:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"hypothesesList", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      "<>", "\"\<\\n\\nSCORED MATRIX (ID: [scores in hypothesis order]):\\n\>\
\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"MapIndexed", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"ToString", "[", 
             RowBox[{"#2", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
            RowBox[{"evidenceList", "[", 
             RowBox[{"[", 
              RowBox[{"#2", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], 
            "<>", "\"\<: \>\"", "<>", 
            RowBox[{"StringJoin", "[", 
             RowBox[{"Riffle", "[", 
              RowBox[{"#1", ",", "\"\<, \>\""}], "]"}], "]"}], 
            "<>", "\"\<\\n\>\""}], ")"}], "&"}], ",", "aiMatrix"}], "]"}], 
       "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumptionResponse", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"assumptionPrompt", ",", "0.2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"assumptionClean", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", "assumptionResponse", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<assumption_audit.md\>\""}], ",", 
      RowBox[{"\"\<# ACH Assumption Audit Log\\n\\n\>\"", 
       "<>", "\"\<Key assumptions driving contested ratings. Review before \
finalising conclusions.\\n\\n\>\"", "<>", "\"\<```json\\n\>\"", "<>", 
       "assumptionClean", "<>", "\"\<\\n```\>\""}], ",", "\"\<Text\>\""}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Assumption audit saved to \
Vault/assumption_audit.md\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "Format"}]}], " ", "and", " ", "export", " ", "Markdown", 
     " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"table", "--"}], "--"}], "--"}], "--"}], "--"}], 
             "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}]}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Formatting Markdown Table ---\>\"", "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"headerRow", "=", 
     RowBox[{"\"\<| Evidence | \>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{
         RowBox[{"ToString", "/@", "hypothesesList"}], ",", "\"\< | \>\""}], 
        "]"}], "]"}], "<>", "\"\< |\\n\>\""}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"separatorRow", "=", 
     RowBox[{"\"\<|---\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Table", "[", 
        RowBox[{"\"\<|---\>\"", ",", 
         RowBox[{"{", "numCols", "}"}]}], "]"}], "]"}], 
      "<>", "\"\<|\\n\>\""}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dataRows", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<| \>\"", "<>", 
         RowBox[{"evidenceList", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "<>", "\"\< | \>\"", "<>", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"Riffle", "[", 
           RowBox[{
            RowBox[{"ToString", "/@", 
             RowBox[{"aiMatrix", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", "\"\< | \>\""}], "]"}], 
          "]"}], "<>", "\"\< |\\n\>\""}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "numRows"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mdTable", "=", 
     RowBox[{"headerRow", "<>", "separatorRow", "<>", "dataRows"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<ai_scored_matrix.md\>\""}], ",", 
      "mdTable", ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<ai_scored_matrix.json\>\""}], ",", 
      "aiMatrix"}], "]"}], ";"}], "\n", 

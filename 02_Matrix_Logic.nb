Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"02", ":", 
    RowBox[{
     RowBox[{"Matrix", " ", "Logic"}], "-", 
     RowBox[{"DYNAMIC", " ", "AI", " ", "EXECUTION"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing Dynamic ACH Engine ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "<<", "\"\</Users/Western/Desktop/ThesisCode/Core_API_Functions.wl\>\""}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"geminiService", "=", 
     RowBox[{"ServiceConnect", "[", "\"\<GoogleGemini\>\"", "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "IMPORT"}]}], " ", "VAULT", " ", 
      RowBox[{"DATA", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "evidencePath", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_vault.md\>\""}\
], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "hypothesesPath", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/target_hypotheses.md\>\
\""}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"evidenceList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{"evidencePath", ",", "\"\<Text\>\""}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], "]"}], ",", "\"\<\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"hypothesesList", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringSplit", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{"hypothesesPath", ",", "\"\<Text\>\""}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], "]"}], ",", "\"\<\>\""}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Target Hypotheses Loaded: \>\"", ",", 
      RowBox[{"Length", "[", "hypothesesList", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Evidence Items Loaded: \>\"", ",", 
      RowBox[{"Length", "[", "evidenceList", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "THE"}]}], " ", "GEMINI", " ", "GOD", " ", 
      RowBox[{"PROMPT", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Constructing the LLM Grading Prompt ---\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "systemInstructions", 
     "=", "\"\<You are an expert intelligence analyst executing the Analysis \
of Competing Hypotheses (ACH). \nI will provide a list of Evidence and a list \
of Hypotheses. You must score every piece of evidence against every \
hypothesis. \nUse ONLY the following exact strings: \\\"C\\\", \\\"I\\\", \
\\\"II\\\", \\\"N\\\", \\\"NA\\\". \n\nYou must output your response STRICTLY \
as a JSON array of arrays (a 2D matrix). \nRows must represent the Evidence. \
Columns must represent the Hypotheses.\nDo not include markdown blocks, \
explanations, or any other text. Output ONLY the raw JSON array like this: [[\
\\\"C\\\", \\\"I\\\"], [\\\"N\\\", \\\"II\\\"]]\>\""}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"evidenceString", "=", 
     RowBox[{"\"\<EVIDENCE LIST:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"evidenceList", ",", "\"\<\\n\>\""}], "]"}], "]"}]}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"hypothesesString", "=", 
     RowBox[{"\"\<HYPOTHESES LIST:\\n\>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"hypothesesList", ",", "\"\<\\n\>\""}], "]"}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"fullPrompt", "=", 
     RowBox[{
     "systemInstructions", "<>", "\"\<\\n\\n\>\"", "<>", "evidenceString", 
      "<>", "\"\<\\n\\n\>\"", "<>", "hypothesesString"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXECUTE"}]}], " ", "API", " ", 
      RowBox[{"CALL", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Sending Matrix to Gemini API ---\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"rawResponse", "=", 
     RowBox[{"rateLimitedExecute", "[", 
      RowBox[{"geminiService", ",", "\"\<Chat\>\"", ",", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Messages\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Role\>\"", "->", "\"\<user\>\""}], ",", 
             RowBox[{"\"\<Content\>\"", "->", "fullPrompt"}]}], "|>"}], 
           "}"}]}], ",", 
         RowBox[{"\"\<Model\>\"", "->", "\"\<gemini-2.5-flash\>\""}], ",", 
         RowBox[{"\"\<Temperature\>\"", "->", "0.0"}]}], "|>"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Parse", " ", "JSON", " ", "Response"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanJSON", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{
       RowBox[{"rawResponse", "[", "\"\<Content\>\"", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"aiMatrix", "=", 
     RowBox[{"ImportString", "[", 
      RowBox[{"cleanJSON", ",", "\"\<JSON\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\:2705 AI Matrix Scored! Dimensions: \>\"", ",", 
      RowBox[{"Dimensions", "[", "aiMatrix", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXPORT"}]}], " ", 
      RowBox[{"MATRIX", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/ai_scored_matrix.\
json\>\"", ",", "aiMatrix"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\:2705 Matrix exported to Vault. Ready for Notebook \
03.\>\"", "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9812051215895367`*^9, 3.98120512159269*^9}, 

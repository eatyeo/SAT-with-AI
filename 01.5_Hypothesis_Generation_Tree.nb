  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Get", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], 
      "<>", "\"\<Core_API_Functions.wl\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing MHG Permutation Tree ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"numberedEvidence", "=", 
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"$vaultDir", "<>", "\"\<evidence_vault.md\>\""}], 
       ",", "\"\<Text\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Vault evidence loaded.\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"centralQuestionFile", "=", 
     RowBox[{"$vaultDir", "<>", "\"\<central_question.md\>\""}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"centralQuestionContext", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"FileExistsQ", "[", "centralQuestionFile", "]"}], ",", 
       RowBox[{"\"\<The central analytical question for this case is:\\n\>\"",
         "<>", 
        RowBox[{"StringReplace", "[", 
         RowBox[{
          RowBox[{"Import", "[", 
           RowBox[{"centralQuestionFile", ",", "\"\<Text\>\""}], "]"}], ",", 
          
          RowBox[{"\"\<# Central Analytical Question\\n\\n\>\"", 
           "->", "\"\<\>\""}]}], "]"}], "<>", "\"\<\\n\\n\>\""}], 
       ",", "\"\<\>\""}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"STEP", " ", "1"}], ":", 
     RowBox[{"Identify", " ", "analytical", " ", "dimensions"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- STEP 1: Identifying Analytical Dimensions ---\>\
\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"dimensionPrompt", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst applying the \
Multiple \>\"", 
      "<>", "\"\<Hypotheses Generator (MHG) from Beebe & Pherson \
(2015).\\n\\n\>\"", "<>", "centralQuestionContext", 
      "<>", "\"\<Identify the 2-3 most analytically useful component \
dimensions \>\"", 
      "<>", "\"\<for this case. The most useful are ones like:\\n\>\"", 
      "<>", "\"\<- WHO is affected or responsible?\\n\>\"", 
      "<>", "\"\<- WHAT is the mechanism or agent?\\n\>\"", 
      "<>", "\"\<- WHY / HOW did it happen (intentional, accidental, \
natural)?\\n\\n\>\"", 
      "<>", "\"\<Pick dimensions where different answers lead to meaningfully \
\>\"", "<>", "\"\<different hypotheses. For each, provide 2-4 mutually \
exclusive options.\\n\\n\>\"", 
      "<>", "\"\<Output ONLY valid JSON in exactly this structure:\\n\>\"", 
      "<>", "\"\<{\\n\>\"", "<>", "\"\<  \\\"dimensions\\\": [\\n\>\"", 
      "<>", "\"\<    {\\\"name\\\": \\\"Who?\\\", \\\"options\\\": [\\\"Only \
Navajos\\\", \\\"Anyone\\\"]},\\n\>\"", 
      "<>", "\"\<    {\\\"name\\\": \\\"What?\\\", \\\"options\\\": \
[\\\"Common flu\\\", \\\"Unknown pathogen\\\", \\\"Chemical toxin\\\"]},\\n\>\
\"", "<>", "\"\<    {\\\"name\\\": \\\"Why?\\\", \\\"options\\\": [\\\"Act of \
nature\\\", \\\"Intentional act\\\", \\\"Accidental exposure\\\"]}\\n\>\"", 
      "<>", "\"\<  ]\\n\>\"", "<>", "\"\<}\\n\\n\>\"", 
      "<>", "\"\<No markdown, no explanation, no extra keys. Raw JSON \
only.\\n\\n\>\"", "<>", "\"\<Evidence:\\n\>\"", "<>", "numberedEvidence"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"rawDimensions", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"dimensionPrompt", ",", "0.2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleanDimensions", "=", 
     RowBox[{"StringTrim", "[", "rawDimensions", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleanDimensions", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"cleanDimensions", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"dimData", "=", 
     RowBox[{"ImportString", "[", 
      RowBox[{"cleanDimensions", ",", "\"\<RawJSON\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"dimData", "===", "$Failed"}], "||", 
       RowBox[{"!", 
        RowBox[{"AssociationQ", "[", "dimData", "]"}]}], "||", 
       RowBox[{"!", 
        RowBox[{"KeyExistsQ", "[", 
         RowBox[{"dimData", ",", "\"\<dimensions\>\""}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[ERROR] Failed to parse dimension JSON. Raw: \>\"", "<>",
          "rawDimensions"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"dimensions", "=", 
     RowBox[{"dimData", "[", "\"\<dimensions\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Validated] \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "dimensions", "]"}], "]"}], 
      "<>", "\"\< dimensions:\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  \>\"", "<>", 
        RowBox[{
         RowBox[{"dimensions", "[", 
          RowBox[{"[", "d", "]"}], "]"}], "[", "\"\<name\>\"", "]"}], 
        "<>", "\"\<: \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"dimensions", "[", 
             RowBox[{"[", "d", "]"}], "]"}], "[", "\"\<options\>\"", "]"}], 
           ",", "\"\<, \>\""}], "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"d", ",", 
        RowBox[{"Length", "[", "dimensions", "]"}]}], "}"}]}], "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"STEP", " ", "2"}], ":", 
     RowBox[{"Generate", " ", "all", " ", "permutations"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- STEP 2: Generating All Permutations ---\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"dimNames", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", "\"\<name\>\"", "]"}], "&"}], ",", "dimensions"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"optionLists", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", "\"\<options\>\"", "]"}], "&"}], ",", 
       "dimensions"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allCombinations", "=", 
     RowBox[{"Tuples", "[", "optionLists", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numPermutations", "=", 
     RowBox[{"Length", "[", "allCombinations", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Total permutations before scoring: \>\"", "<>", 
      RowBox[{"ToString", "[", "numPermutations", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"permutationSentences", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"combo", ",", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"Riffle", "[", 
           RowBox[{
            RowBox[{"MapThread", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#1", "<>", "\"\<: \>\"", "<>", "#2"}], ")"}], "&"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"dimNames", ",", "combo"}], "}"}]}], "]"}], 
            ",", "\"\< | \>\""}], "]"}], "]"}]}], "]"}], ",", 
       "allCombinations"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"STEP", " ", "3"}], ":", 
     RowBox[{"Score", " ", "permutations"}]}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- STEP 3: Scoring Permutations ---\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"permutationBlock", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"MapIndexed", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ToString", "[", 
            RowBox[{"#2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
           "#1", "<>", "\"\<\\n\>\""}], ")"}], "&"}], ",", 
        "permutationSentences"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"scoringPrompt", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst applying the \
Multiple \>\"", 
      "<>", "\"\<Hypotheses Generator (MHG) from Beebe & Pherson \
(2015).\\n\\n\>\"", "<>", "centralQuestionContext", 
      "<>", "\"\<Score each permutation 1-5 for credibility, or \\\"discard\\\
\" if \>\"", 
      "<>", "\"\<logically contradictory or implausible given the \
evidence.\\n\\n\>\"", 
      "<>", "\"\<Output ONLY a JSON array, one object per permutation, same \
order as input:\\n\>\"", 
      "<>", "\"\<[{\\\"permutation\\\": \\\"...\\\", \\\"score\\\": 3, \>\"", 
      "<>", "\"\<\\\"hypothesis\\\": \\\"Plain English statement of this \
scenario.\\\"},\\n\>\"", 
      "<>", "\"\< {\\\"permutation\\\": \\\"...\\\", \\\"score\\\": \
\\\"discard\\\", \\\"hypothesis\\\": \\\"\\\"}]\\n\\n\>\"", 
      "<>", "\"\<The hypothesis field is a single plain English sentence \
restating \>\"", 
      "<>", "\"\<the permutation as a testable claim (e.g. \\\"People are \
dying from a \>\"", 
      "<>", "\"\<naturally occurring unknown pathogen.\\\"). \>\"", 
      "<>", "\"\<Leave empty string for discarded items.\\n\\n\>\"", 
      "<>", "\"\<No markdown, no explanation. Raw JSON array only.\\n\\n\>\"",
       "<>", "\"\<Evidence:\\n\>\"", "<>", "numberedEvidence", 
      "<>", "\"\<\\n\\n\>\"", "<>", "\"\<Permutations to score:\\n\>\"", "<>",
       "permutationBlock"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"rawScoring", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"scoringPrompt", ",", "0.2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleanScoring", "=", 
     RowBox[{"StringTrim", "[", "rawScoring", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleanScoring", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"cleanScoring", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"scoredData", "=", 
     RowBox[{"ImportString", "[", 
      RowBox[{"cleanScoring", ",", "\"\<RawJSON\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"scoredData", "===", "$Failed"}], "||", 
       RowBox[{"!", 
        RowBox[{"ListQ", "[", "scoredData", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[ERROR] Failed to parse scoring JSON. Raw: \>\"", "<>", 
         "rawScoring"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<[Validated] \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "scoredData", "]"}], "]"}], 
      "<>", "\"\< permutations scored.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"keptPermutations", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"scoredData", ",", 
       RowBox[{"Function", "[", 
        RowBox[{"p", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"p", "[", "\"\<score\>\"", "]"}], 
           "=!=", "\"\<discard\>\""}], "&&", 
          RowBox[{
           RowBox[{"p", "[", "\"\<score\>\"", "]"}], "=!=", "0"}], "&&", 
          RowBox[{"StringQ", "[", 
           RowBox[{"p", "[", "\"\<hypothesis\>\"", "]"}], "]"}], "&&", 
          RowBox[{
           RowBox[{"StringLength", "[", 
            RowBox[{"p", "[", "\"\<hypothesis\>\"", "]"}], "]"}], ">", 
           "0"}]}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"discardedPermutations", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"scoredData", ",", 
       RowBox[{"Function", "[", 
        RowBox[{"p", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"p", "[", "\"\<score\>\"", "]"}], 
           "===", "\"\<discard\>\""}], "||", 
          RowBox[{
           RowBox[{"p", "[", "\"\<score\>\"", "]"}], "===", "0"}]}]}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Kept: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "keptPermutations", "]"}], "]"}], 
      "<>", "\"\< | Discarded: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "discardedPermutations", "]"}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"keptPermutations", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"keptPermutations", ",", 
       RowBox[{"Function", "[", 
        RowBox[{"p", ",", 
         RowBox[{"-", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"NumberQ", "[", 
             RowBox[{"p", "[", "\"\<score\>\"", "]"}], "]"}], ",", 
            RowBox[{"p", "[", "\"\<score\>\"", "]"}], ",", "0"}], "]"}]}]}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"maxHypotheses", "=", "5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"finalHypotheses", "=", 
     RowBox[{"MapIndexed", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\"\<H\>\"", "<>", 
          RowBox[{"ToString", "[", 
           RowBox[{"#2", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<: \>\"", "<>", 
          RowBox[{"#1", "[", "\"\<hypothesis\>\"", "]"}]}], ")"}], "&"}], ",", 
       RowBox[{"Take", "[", 
        RowBox[{"keptPermutations", ",", 
         RowBox[{"UpTo", "[", "maxHypotheses", "]"}]}], "]"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nFinal hypotheses (survivors):\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  \>\"", "<>", 
        RowBox[{"finalHypotheses", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "finalHypotheses", "]"}]}], "}"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<target_hypotheses.md\>\""}], ",", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"finalHypotheses", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Hypotheses exported to Vault.\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"FIX", ":", 
     RowBox[{"replace", "|", 
      RowBox[{
      "in", " ", "permutation", " ", "strings", " ", "so", " ", "they", " ", 
       RowBox[{"don", "'"}], "t", " ", "break", " ", "markdown", " ", 
       "columns"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"safePermutation", "[", "s_", "]"}], ":=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"s", ",", 
       RowBox[{"\"\< | \>\"", "->", "\"\< / \>\""}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<permutation_scores.md\>\""}], ",", 
      RowBox[{"\"\<# MHG Permutation Scoring\\n\\n\>\"", 
       "<>", "\"\<| # | Permutation | Score | Hypothesis |\\n\>\"", 
       "<>", "\"\<|---|---|---|---|\\n\>\"", "<>", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"MapIndexed", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\"\<| \>\"", "<>", 
             RowBox[{"ToString", "[", 
              RowBox[{"#2", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\< | \>\"", "<>", 
             RowBox[{"safePermutation", "[", 
              RowBox[{"#1", "[", "\"\<permutation\>\"", "]"}], "]"}], 
             "<>", "\"\< | \>\"", "<>", 
             RowBox[{"ToString", "[", 
              RowBox[{"#1", "[", "\"\<score\>\"", "]"}], "]"}], 
             "<>", "\"\< | \>\"", "<>", 
             RowBox[{"#1", "[", "\"\<hypothesis\>\"", "]"}], 
             "<>", "\"\< |\\n\>\""}], ")"}], "&"}], ",", "scoredData"}], 
         "]"}], "]"}]}], ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Scoring table saved to \
Vault/permutation_scores.md\>\"", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "==="}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"STEP", " ", "4"}], ":", 
     RowBox[{"Permutation", " ", "Tree", " ", "Visualization"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",

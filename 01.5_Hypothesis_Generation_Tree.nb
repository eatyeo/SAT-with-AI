       RowBox[{"nodeKey", "=", 
        RowBox[{"\"\<D1_\>\"", "<>", "d1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"allNodes", ",", "nodeKey"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"allEdges", ",", 
         RowBox[{"DirectedEdge", "[", 

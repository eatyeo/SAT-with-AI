   RowBox[{
    RowBox[{"nodeTypes", "=", 
     RowBox[{"<|", 
      RowBox[{"\"\<__ROOT__\>\"", "->", "\"\<root\>\""}], "|>"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nodeScores", "=", 
     RowBox[{"<|", "|>"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"numDims", "=", 
     RowBox[{"Min", "[", 
      RowBox[{
       RowBox[{"Length", "[", "dimensions", "]"}], ",", "3"}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"dim1Options", "=", 
     RowBox[{
      RowBox[{"dimensions", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<options\>\"", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 

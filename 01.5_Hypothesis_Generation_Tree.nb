                    RowBox[{
                    RowBox[{"matchedScore", "=", 
                    RowBox[{
                    RowBox[{"scoredData", "[", 
                    RowBox[{"[", "s", "]"}], "]"}], "[", "\"\<score\>\"", 
                    "]"}]}], ";", 
                    RowBox[{"Break", "[", "]"}]}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"s", ",", 
                    RowBox[{"Length", "[", "scoredData", "]"}]}], "}"}]}], 
                 "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"nodeScores", "[", "nodeKey", "]"}], "=", 
                 "matchedScore"}], ";"}]}], "]"}], ";"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", 
              RowBox[{"Length", "[", "dim2Options", "]"}]}], "}"}]}], "]"}]}],

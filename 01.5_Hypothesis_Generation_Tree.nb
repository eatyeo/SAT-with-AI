       RowBox[{"\"\<WHAT: Unknown Pathogen\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Intentional Act\\nCredibility: \
3\\n(Pathogen Discarded)\>\""}], ",", 
       RowBox[{"\"\<WHAT: Unknown Pathogen\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Accidental\\n(Pathogen Discarded)\>\""}],
        ",", 
       RowBox[{"\"\<WHAT: Chemical Toxin\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Act of Nature\\nCredibility: 1\\n(Toxin \

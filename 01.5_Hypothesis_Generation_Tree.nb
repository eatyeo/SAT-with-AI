       RowBox[{"\"\<WHAT: Chemical Toxin\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Accidental\\n(Toxin Discarded)\>\""}], ",", 
       RowBox[{"\"\<WHO: General Population\\n(Indiscriminate)\>\"", 
        "\[DirectedEdge]", "\"\<WHAT: Flu (General)\>\""}], ",", 
       RowBox[{"\"\<WHAT: Flu (General)\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Act of Nature\\nCredibility: 4\\n[H1: \

        RowBox[{"Style", "[", 
         RowBox[{"\"\<Multiple Hypotheses Generator: Pruned Permutation Logic\
\>\"", ",", "Bold", ",", "16", ",", 
          RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/Permutation_Tree_\
Master.pdf\>\"", ",", "treePlot"}], "]"}], ";"}], "\n", 

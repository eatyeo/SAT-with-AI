   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"numDims", ">=", "2"}], ",", 
      RowBox[{
       RowBox[{"dim2Options", "=", 
        RowBox[{
         RowBox[{"dimensions", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "[", "\"\<options\>\"", "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"d1", "=", 

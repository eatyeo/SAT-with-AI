          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"d2", "=", 
              RowBox[{"dim2Options", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"parentKey", "=", 
              
              RowBox[{"\"\<D1_\>\"", "<>", "d1", "<>", "\"\<|D2_\>\"", "<>", 
               "d2"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"d3", "=", 
                 RowBox[{"dim3Options", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"leafKey", "=", 
                 
                 RowBox[{"\"\<D1_\>\"", "<>", "d1", "<>", "\"\<|D2_\>\"", "<>",

                "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"allNodes", ",", "leafKey"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"allEdges", ",", 
                  RowBox[{"DirectedEdge", "[", 
                   RowBox[{"parentKey", ",", "leafKey"}], "]"}]}], "]"}], ";",
                 "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"nodeLabels", "[", "leafKey", "]"}], "=", "d3"}], ";",
                 "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"nodeTypes", "[", "leafKey", "]"}], 
                 "=", "\"\<leaf\>\""}], ";", "\[IndentingNewLine]", 
                RowBox[{"matchedScore", "=", "\"\<discard\>\""}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"Do", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"StringContainsQ", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"scoredData", "[", 
                    RowBox[{"[", "s", "]"}], "]"}], "[", "\"\<permutation\>\"",
                     "]"}], ",", "d1"}], "]"}], "&&", 
                    RowBox[{"StringContainsQ", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"scoredData", "[", 
                    RowBox[{"[", "s", "]"}], "]"}], "[", "\"\<permutation\>\"",
                     "]"}], ",", "d2"}], "]"}], "&&", 
                    RowBox[{"StringContainsQ", "[", 

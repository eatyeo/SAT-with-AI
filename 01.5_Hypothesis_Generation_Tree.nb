        RowBox[{"StringTake", "[", 
         RowBox[{"rootLabel", ",", "40"}], "]"}], "<>", "\"\<...\>\""}], ",", 
       "rootLabel"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allNodes", "=", 

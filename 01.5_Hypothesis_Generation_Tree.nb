     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"vertexShapeFunc", "=", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"coords", ",", "name", ",", "size"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"ntype", ",", "label", ",", "score"}], "}"}], ",", 
         RowBox[{
          RowBox[{"ntype", "=", 
           RowBox[{"Lookup", "[", 
            RowBox[{"nodeTypes", ",", "name", ",", "\"\<dim1\>\""}], "]"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"label", "=", 
           RowBox[{"Lookup", "[", 
            RowBox[{"nodeLabels", ",", "name", ",", "name"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"score", "=", 
           RowBox[{"Lookup", "[", 
            RowBox[{"nodeScores", ",", "name", ",", 

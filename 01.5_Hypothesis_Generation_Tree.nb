              RowBox[{"nodeStyle", "[", 
               RowBox[{"label", ",", 
                RowBox[{"GrayLevel", "[", "0.25", "]"}], ",", "160"}], "]"}], 
              ",", "coords"}], "]"}], ",", 
            RowBox[{"ntype", "===", "\"\<leaf\>\""}], ",", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"leafStyle", "[", 
               RowBox[{"label", ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"MissingQ", "[", "score", "]"}], 

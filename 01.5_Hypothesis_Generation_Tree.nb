      RowBox[{
       RowBox[{"dim2Options", "=", 
        RowBox[{
         RowBox[{"dimensions", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "[", "\"\<options\>\"", "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"dim3Options", "=", 
        RowBox[{
         RowBox[{"dimensions", "[", 

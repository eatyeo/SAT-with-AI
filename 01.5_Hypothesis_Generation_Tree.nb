       RowBox[{"\"\<WHAT: Flu (General)\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Other Causes\\n(Other \
Discarded)\>\""}]}], "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"ClearAll", "[", "nodeAesthetic", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"nodeAesthetic", "[", "name_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "bgColor", ",", "fontColor", ",", "borderColor", ",", 
         "textToDisplay"}], "}"}], ",", 
       RowBox[{
        RowBox[{"textToDisplay", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"name", ",", 
           RowBox[{"{", 
            RowBox[{
             
             RowBox[{"\"\<(Flu Discarded)\>\"", 
              "->", "\"\<Status: DISCARD\>\""}], ",", 
             
             RowBox[{"\"\<(Pathogen Discarded)\>\"", 
              "->", "\"\<Status: DISCARD\>\""}], ",", 
             
             RowBox[{"\"\<(Toxin Discarded)\>\"", 
              "->", "\"\<Status: DISCARD\>\""}], ",", 
             
             RowBox[{"\"\<(Other Discarded)\>\"", 
              "->", "\"\<Status: DISCARD\>\""}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<[H\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Blue", ",", "0.9"}], "]"}]}], ";", 
           RowBox[{"fontColor", "=", 
            RowBox[{"Darker", "[", 
             RowBox[{"Blue", ",", "0.4"}], "]"}]}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Blue", ",", "0.4"}], "]"}]}], ";"}], ",", 
          RowBox[{
           RowBox[{"StringContainsQ", "[", 
            RowBox[{"name", ",", "\"\<DISCARD\>\""}], "]"}], "||", 
           RowBox[{"StringContainsQ", "[", 
            RowBox[{"name", ",", "\"\<Discarded\>\""}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"GrayLevel", "[", "0.96", "]"}]}], ";", 
           RowBox[{"fontColor", "=", 
            RowBox[{"GrayLevel", "[", "0.6", "]"}]}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"GrayLevel", "[", "0.9", "]"}]}], ";"}], ",", 
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<Sudden Deaths\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"GrayLevel", "[", "0.15", "]"}]}], ";", 
           RowBox[{"fontColor", "=", "White"}], ";", 
           RowBox[{"borderColor", "=", "Black"}], ";"}], ",", "True", ",", 
          RowBox[{
           RowBox[{"bgColor", "=", "White"}], ";", 
           RowBox[{"fontColor", "=", "Black"}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"GrayLevel", "[", "0.7", "]"}]}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Framed", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"textToDisplay", ",", "10", ",", 
            RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}], ",", "Bold", ",", 
            RowBox[{"FontColor", "->", "fontColor"}], ",", 
            RowBox[{"TextAlignment", "->", "Center"}]}], "]"}], ",", 
          RowBox[{"Background", "->", "bgColor"}], ",", 
          RowBox[{"FrameStyle", "->", 
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{"Thickness", "[", "0.003", "]"}], ",", "borderColor"}], 
            "]"}]}], ",", 
          RowBox[{"RoundingRadius", "->", "6"}], ",", 
          RowBox[{"FrameMargins", "->", "10"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Generating Master MHG Permutation Tree ---\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"treePlot", "=", 
     RowBox[{"Graph", "[", 
      RowBox[{"edges", ",", 
       RowBox[{"VertexShapeFunction", "->", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Inset", "[", 
           RowBox[{
            RowBox[{"nodeAesthetic", "[", "#2", "]"}], ",", "#1"}], "]"}], 
          "&"}], ")"}]}], ",", 
       RowBox[{"EdgeStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Darker", "[", 
           RowBox[{"Gray", ",", "0.4"}], "]"}], ",", 
          RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "]"}]}], ",", 
       RowBox[{"GraphLayout", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<LayeredDigraphEmbedding\>\"", ",", 
          RowBox[{"\"\<RootVertex\>\"", "->", "\"\<Sudden Deaths\>\""}], ",", 
          
          RowBox[{"\"\<Orientation\>\"", "->", "Left"}]}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"1000", ",", "800"}], "}"}]}], ",", 

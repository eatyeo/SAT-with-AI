  RowBox[{
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing Advanced Combinatorial Logic Tree ---\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"edges", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<Sudden Deaths\>\"", 
        "\[DirectedEdge]", "\"\<WHO: Isolated Demographic\\n(Navajos \
Only)\>\""}], ",", 
       RowBox[{"\"\<Sudden Deaths\>\"", 
        "\[DirectedEdge]", "\"\<WHO: General \
Population\\n(Indiscriminate)\>\""}], ",", 
       RowBox[{"\"\<WHO: Isolated Demographic\\n(Navajos Only)\>\"", 
        "\[DirectedEdge]", "\"\<WHAT: Virulent Flu\>\""}], ",", 
       RowBox[{"\"\<WHO: Isolated Demographic\\n(Navajos Only)\>\"", 
        "\[DirectedEdge]", "\"\<WHAT: Unknown Pathogen\>\""}], ",", 
       RowBox[{"\"\<WHO: Isolated Demographic\\n(Navajos Only)\>\"", 
        "\[DirectedEdge]", "\"\<WHAT: Chemical Toxin\>\""}], ",", 
       RowBox[{"\"\<WHAT: Virulent Flu\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Act of Nature\\n(Flu Discarded)\>\""}], ",", 
       RowBox[{"\"\<WHAT: Virulent Flu\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Intentional Act\\n(Flu Discarded)\>\""}],
        ",", 
       RowBox[{"\"\<WHAT: Virulent Flu\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Accidental\\n(Flu Discarded)\>\""}], ",", 
       RowBox[{"\"\<WHAT: Unknown Pathogen\>\"", 
        "\[DirectedEdge]", "\"\<WHY: Act of Nature\\nCredibility: 1\\n[H4: \

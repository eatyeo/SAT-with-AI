Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===",
     " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", 
    " ", "===", " ", "===", " ", "===", " ", "===", " ", "==="}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"01.5", ":", 
    RowBox[{
     RowBox[{"Hypothesis", " ", "Generation"}], " ", "-", " ", 
     RowBox[{"MHG", " ", "TREE"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===",
     " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", 
    " ", "===", " ", "===", " ", "===", " ", "===", " ", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "<<", "\"\</Users/Western/Desktop/ThesisCode/Core_API_Functions.wl\>\""}],
     ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Initializing Advanced Combinatorial Logic Tree ---\
\>\"", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Load"}]}], " ", "consensus"}], "-", 
     RowBox[{"approved", " ", "evidence", " ", "from", " ", 
      RowBox[{"Vault", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "vaultPath", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_vault.md\>\""}\
], ";"}], "\n", 
   RowBox[{
    RowBox[{"numberedEvidence", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"vaultPath", ",", "\"\<Text\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Vault evidence loaded.\>\"", "]"}], ";"}],
    "\n", "\n", 
   RowBox[{
    RowBox[{"hypothesisPrompt", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst applying the \
Multiple Hypotheses Generator (MHG) technique from Beebe & Pherson (2015).\\n\
\\nYour task: generate a WHO -> WHAT -> WHY hypothesis permutation tree from \
the verified evidence below.\\n\\nSTRICT STRUCTURE RULES - these are \
non-negotiable:\\n1. The root node must be exactly: \\\"Sudden \
Deaths\\\"\\n2. Level 1 (WHO): Abstract the victims into exactly TWO mutually \
exclusive demographic groups based on the evidence. Do not list individuals \
or specific symptoms as WHO nodes. WHO answers: who is the affected \
population?\\n   - One branch for a specific/isolated demographic (e.g. only \
Navajos)\\n   - One branch for a general/indiscriminate population (e.g. \
anyone)\\n3. Level 2 (WHAT): For EACH WHO branch, generate 2-3 plausible \
disease agents or mechanisms. WHAT answers: what type of agent or \
mechanism?\\n4. Level 3 (WHY - TERMINAL NODES ONLY): For EACH WHAT branch, \
generate exactly 3 causes: Act of Nature, Intentional Act, Accidental \
Exposure.\\n5. Every path MUST go: Root -> WHO -> WHAT -> WHY. No skipping \
levels.\\n6. Low credibility terminal nodes must end with (X Discarded).\\n7. \
Active hypothesis terminal nodes must include [H#: short label] and \
Credibility: N where N is 1-4.\\n\\nOutput ONLY a valid JSON array of edge \
pairs. No explanation, no markdown.\\nFormat: [[\\\"Sudden Deaths\\\", \
\\\"WHO: ...\\\"], [\\\"WHO: ...\\\", \\\"WHAT: ...\\\"], [\\\"WHAT: ...\\\", \
\\\"WHY: ...\\\\nCredibility: N\\\\n[H#: Label]\\\"]]\\n\\nEvidence:\\n>\>\"",
       "<>", "numberedEvidence"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Querying Gemini for Dynamic Hypothesis Tree ---\
\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rawResponse", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"hypothesisPrompt", ",", "0.2"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Parse"}]}], " ", "JSON", " ", "response", " ", "into", " ", 
      RowBox[{"edges", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"jsonText", "=", 
     RowBox[{"StringTrim", "[", "rawResponse", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"jsonText", "=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"jsonText", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<```json\\n\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```json\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<```\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{
    RowBox[{"edgePairs", "=", 
     RowBox[{"ImportString", "[", 
      RowBox[{"jsonText", ",", "\"\<JSON\>\""}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Fail", "-", 
     RowBox[{
     "safe", " ", "check", " ", "to", " ", "prevent", " ", "graph", " ", 
      "generation", " ", "crashes"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"edgePairs", "===", "$Failed"}], "||", 
       RowBox[{"!", 
        RowBox[{"ListQ", "[", "edgePairs", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[ERROR] Failed to parse JSON. Raw response:\\n\>\"", ",",
          "rawResponse"}], "]"}], ";", "\n", 
       RowBox[{"Abort", "[", "]"}], ";"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"edges", "=", 
     RowBox[{"DirectedEdge", "@@@", "edgePairs"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Generated \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "edges", "]"}], "]"}], 
      "<>", "\"\< edges from vault evidence.\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Node"}]}], " ", 
      RowBox[{"styling", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"ClearAll", "[", "nodeAesthetic", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"nodeAesthetic", "[", "name_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "bgColor", ",", "fontColor", ",", "borderColor", ",", 
         "textToDisplay"}], "}"}], ",", 
       RowBox[{
        RowBox[{"textToDisplay", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"name", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
             "RegularExpression", "[", "\"\<\\\\([^)]+Discarded\\\\)\>\"", 
              "]"}], "->", "\"\<Status: DISCARD\>\""}], "}"}]}], "]"}]}], ";",
         "\n", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<[H\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Blue", ",", "0.9"}], "]"}]}], ";", 
           RowBox[{"fontColor", "=", 
            RowBox[{"Darker", "[", 
             RowBox[{"Blue", ",", "0.4"}], "]"}]}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Blue", ",", "0.4"}], "]"}]}], ";"}], ",", 
          RowBox[{
           RowBox[{"StringContainsQ", "[", 
            RowBox[{"name", ",", "\"\<DISCARD\>\""}], "]"}], "||", 
           RowBox[{"StringContainsQ", "[", 
            RowBox[{"name", ",", "\"\<Discarded\>\""}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"GrayLevel", "[", "0.96", "]"}]}], ";", 
           RowBox[{"fontColor", "=", 
            RowBox[{"GrayLevel", "[", "0.6", "]"}]}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"GrayLevel", "[", "0.9", "]"}]}], ";"}], ",", 
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<Sudden Deaths\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"GrayLevel", "[", "0.15", "]"}]}], ";", 
           RowBox[{"fontColor", "=", "White"}], ";", 
           RowBox[{"borderColor", "=", "Black"}], ";"}], ",", 
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<WHO:\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Gray", ",", "0.85"}], "]"}]}], ";", 
           RowBox[{"fontColor", "=", "Black"}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"GrayLevel", "[", "0.6", "]"}]}], ";"}], ",", 
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"name", ",", "\"\<WHAT:\>\""}], "]"}], ",", 
          RowBox[{
           RowBox[{"bgColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Orange", ",", "0.85"}], "]"}]}], ";", 
           RowBox[{"fontColor", "=", 
            RowBox[{"Darker", "[", 
             RowBox[{"Orange", ",", "0.4"}], "]"}]}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"Lighter", "[", 
             RowBox[{"Orange", ",", "0.5"}], "]"}]}], ";"}], ",", "True", ",", 
          RowBox[{
           RowBox[{"bgColor", "=", "White"}], ";", 
           RowBox[{"fontColor", "=", "Black"}], ";", 
           RowBox[{"borderColor", "=", 
            RowBox[{"GrayLevel", "[", "0.7", "]"}]}], ";"}]}], "]"}], ";", 
        "\n", 
        RowBox[{"Framed", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"textToDisplay", ",", "10", ",", 
            RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}], ",", "Bold", ",", 
            RowBox[{"FontColor", "->", "fontColor"}], ",", 
            RowBox[{"TextAlignment", "->", "Center"}]}], "]"}], ",", 
          RowBox[{"Background", "->", "bgColor"}], ",", 
          RowBox[{"FrameStyle", "->", 
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{"Thickness", "[", "0.003", "]"}], ",", "borderColor"}], 
            "]"}]}], ",", 
          RowBox[{"RoundingRadius", "->", "6"}], ",", 
          RowBox[{"FrameMargins", "->", "10"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"--", 
        RowBox[{"-", "Build"}]}], "&"}], " ", "export", " ", 
      RowBox[{"tree", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Generating Master MHG Permutation Tree ---\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"treePlot", "=", 
     RowBox[{"Graph", "[", 
      RowBox[{"edges", ",", 
       RowBox[{"VertexShapeFunction", "->", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Inset", "[", 
           RowBox[{
            RowBox[{"nodeAesthetic", "[", "#2", "]"}], ",", "#1"}], "]"}], 
          "&"}], ")"}]}], ",", 
       RowBox[{"EdgeStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Darker", "[", 
           RowBox[{"Gray", ",", "0.4"}], "]"}], ",", 
          RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "]"}]}], ",", 
       RowBox[{"GraphLayout", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<LayeredDigraphEmbedding\>\"", ",", 
          RowBox[{"\"\<RootVertex\>\"", "->", "\"\<Sudden Deaths\>\""}], ",", 
          
          RowBox[{"\"\<Orientation\>\"", "->", "Left"}]}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"1200", ",", "900"}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Multiple Hypotheses Generator: Pruned Permutation Logic\
\>\"", ",", "Bold", ",", "16", ",", 
          RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/Permutation_Tree_\
Master.pdf\>\"", ",", "treePlot"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] MASTER MHG TREE COMPLETE. Graph exported \
to Vault.\>\"", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Dynamically"}]}], " ", "extract", " ", "final", " ", 
      RowBox[{"hypotheses", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"allNodes", "=", 
     RowBox[{"Union", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{"List", "@@@", "edges"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hNodes", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"allNodes", ",", 
       RowBox[{
        RowBox[{"StringContainsQ", "[", 
         RowBox[{"#", ",", "\"\<[H\>\""}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"finalHypotheses", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"StringCases", "[", 
         RowBox[{"#", ",", 
          RowBox[{"\"\<[H\>\"", "~~", 
           RowBox[{"Shortest", "[", "__", "]"}], "~~", "\"\<]\>\""}]}], "]"}],
         "&"}], "/@", "hNodes"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"finalHypotheses", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"finalHypotheses", ",", 
       RowBox[{
        RowBox[{"ToExpression", "[", 
         RowBox[{"First", "[", 
          RowBox[{"StringCases", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"\"\<H\>\"", "~~", 
              RowBox[{"d", ":", 
               RowBox[{"DigitCharacter", ".."}]}]}], ":>", "d"}]}], "]"}], 
          "]"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\</Users/Western/Desktop/ThesisCode/Vault/target_hypotheses.\
md\>\"", ",", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"finalHypotheses", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Target hypotheses dynamically extracted \
and stored in Vault.\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Hypotheses: \>\"", "<>", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"finalHypotheses", ",", "\"\< | \>\""}], "]"}], "]"}]}], 
     "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.981309850933262*^9, 3.981309850935205*^9}, {

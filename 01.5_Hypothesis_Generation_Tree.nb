                RowBox[{"Do", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"StringContainsQ", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"scoredData", "[", 
                    RowBox[{"[", "s", "]"}], "]"}], "[", "\"\<permutation\>\"",
                     "]"}], ",", "d1"}], "]"}], "&&", 
                    RowBox[{"StringContainsQ", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"scoredData", "[", 
                    RowBox[{"[", "s", "]"}], "]"}], "[", "\"\<permutation\>\"",

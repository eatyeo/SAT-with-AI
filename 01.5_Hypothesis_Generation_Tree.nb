                RowBox[{"LineBreakWithin", "->", "True"}]}], "]"}], ",", 
              RowBox[{"Style", "[", 
               RowBox[{"scoreStr", ",", "8", ",", 
                RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}], ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"score", "===", "\"\<discard\>\""}], ",", "Pink", ",",
                   "Yellow"}], "]"}], ",", "Bold"}], "]"}]}], "}"}], ",", 
            RowBox[{"Alignment", "->", "Left"}], ",", 

          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "dim1Options", "]"}]}], "}"}]}], "]"}]}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{

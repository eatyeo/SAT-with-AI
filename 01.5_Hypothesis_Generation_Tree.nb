               "coords"}], "]"}], ",", 
            RowBox[{"ntype", "===", "\"\<dim1\>\""}], ",", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"nodeStyle", "[", 
               RowBox[{"label", ",", 
                RowBox[{"levelColors", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", "130"}], "]"}], ",", 
              "coords"}], "]"}], ",", 
            RowBox[{"ntype", "===", "\"\<dim2\>\""}], ",", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"nodeStyle", "[", 
               RowBox[{"label", ",", 
                RowBox[{"levelColors", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], ",", "120"}], "]"}], ",", 
              "coords"}], "]"}], ",", "True", ",", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"nodeStyle", "[", 
               RowBox[{"label", ",", 
                RowBox[{"levelColors", "[", 
                 RowBox[{"[", "4", "]"}], "]"}], ",", "110"}], "]"}], ",", 
              "coords"}], "]"}]}], "]"}]}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"imageH", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"500", ",", 
       RowBox[{
        RowBox[{"Length", "[", "allNodes", "]"}], "*", "28"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"permTree", "=", 
     RowBox[{"Graph", "[", 
      RowBox[{"allNodes", ",", "allEdges", ",", 
       RowBox[{"VertexShapeFunction", "->", "vertexShapeFunc"}], ",", 
       RowBox[{"EdgeStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"GrayLevel", "[", "0.55", "]"}], ",", 
          RowBox[{"AbsoluteThickness", "[", "1.5", "]"}], ",", 
          RowBox[{"Arrowheads", "[", "0.015", "]"}]}], "]"}]}], ",", 
       RowBox[{"GraphLayout", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<LayeredDigraphEmbedding\>\"", ",", 
          RowBox[{"\"\<RootVertex\>\"", "->", "\"\<__ROOT__\>\""}], ",", 
          RowBox[{"\"\<Orientation\>\"", "->", "Left"}]}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"1000", ",", "imageH"}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{
          
          RowBox[{"\"\<Multiple Hypotheses Generator: Permutation Tree\\n\>\"",
            "<>", "\"\<Green = high credibility (4-5)  |  Orange = medium \
(2-3)  |  Red = discarded\>\""}], ",", "Bold", ",", "12", ",", 
          RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", "permTree", "\n", 

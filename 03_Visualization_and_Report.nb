              RowBox[{"Hypotheses", " ", "AND", " ", "Scores"}], "-", 
              RowBox[{
              "Rotated", " ", "90", " ", "degrees", " ", "to", " ", "prevent",
                " ", "horizontal", " ", "crushing"}]}]}]}], "*)"}], 
          RowBox[{"{", 
           RowBox[{"None", ",", 
            RowBox[{"MapIndexed", "[", 

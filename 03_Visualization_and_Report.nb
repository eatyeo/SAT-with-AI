       RowBox[{"\"\<I\>\"", "->", 
        RowBox[{"-", "1"}]}], ",", 
       RowBox[{"\"\<N\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<NA\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<C\>\"", "->", "1"}], ",", 
       RowBox[{"\"\<CC\>\"", "->", "2"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"numericMatrix", "=", 
     RowBox[{"expertMatrix", "/.", " ", "mathMap"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hypothesisScores", "=", 
     RowBox[{"Total", "[", "numericMatrix", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"visMatrix", "=", 

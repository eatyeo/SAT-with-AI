  RowBox[{"(*", 
   RowBox[{"01", ":", 
    RowBox[{
    "Data", " ", "Ingestion", " ", "and", " ", "Semantic", " ", "Extraction", 
     " ", 
     RowBox[{"(", "EVIDENCE", ")"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===",
     " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", " ", "===", 
    " ", "===", " ", "===", " ", "===", " ", "===", " ", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "<<", "\"\</Users/Western/Desktop/ThesisCode/Core_API_Functions.wl\>\""}],
     ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "filePath", "=", "\"\</Users/Western/Desktop/ThesisCode/case.txt\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<--- Loading Case from: \>\"", "<>", "filePath", 
      "<>", "\"\< ---\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"docText", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"filePath", ",", "\"\<Text\>\""}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Extraction", " ", 
     RowBox[{"prompt", ":", 
      RowBox[{"clinical", " ", "AND", " ", 
       RowBox[{"epidemiological", "/", "environmental"}], " ", "facts"}]}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"prompt", "=", 
     RowBox[{"\"\<Using ONLY the following text, extract all hard facts, \
evidence, and observable findings. This includes:\\n- Clinical symptoms and \
medical findings\\n- Epidemiological patterns (who is affected, case counts, \
spread)\\n- Environmental and ecological observations\\n- Investigative \
findings (lab results, surveys, negative findings)\\nDO NOT extract \
hypotheses, theories, analyst interpretations, or explanations.\\nOutput each \
fact as a single plain sentence on its own line.\\nDo NOT use numbers, \
bullets, dashes, or any other prefix before each sentence.\\nDo NOT use \
Markdown formatting.\\nOne sentence per line, nothing else.\\nText:\\n\>\"", "<>",
       "docText"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"--", 
     RowBox[{"-", 
      RowBox[{"DEBUG", ":", 
       RowBox[{
        RowBox[{
        "Test", " ", "connection", " ", "before", " ", "running", " ", "full",
          " ", 
         RowBox[{"loop", "--"}]}], "-"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<--- Testing Gemini connection ---\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"testRes", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"\"\<Say hello.\>\"", ",", "0.3"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Connection successful.\>\"", "]"}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "EXECUTION"}]}], " ", 
     RowBox[{"LOOP", ":", 
      RowBox[{
       RowBox[{"5", " ", "stochastic", " ", "calls", " ", "for", " ", 
        RowBox[{"consensus", "--"}]}], "-"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"numCalls", "=", "5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "res", "}"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<--- API Call \>\"", "<>", 
            RowBox[{"ToString", "[", "i", "]"}], "<>", "\"\< of \>\"", "<>", 
            RowBox[{"ToString", "[", "numCalls", "]"}], 
            "<>", "\"\< ---\>\""}], "]"}], ";", "\n", 
          RowBox[{"res", "=", 
           RowBox[{"callGemini", "[", 
            RowBox[{"prompt", ",", "0.3"}], "]"}]}], ";", "\n", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"res", "===", "\"\<$Failed\>\""}], ",", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<\\\\[Warning] Call \>\"", "<>", 
               RowBox[{"ToString", "[", "i", "]"}], 
               "<>", "\"\< failed.\>\""}], "]"}], ";", "\n", "\"\<\>\""}], ",",
             "res"}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "numCalls"}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{"allOutputs", ",", 
       RowBox[{"\"\<\>\"", "|", "Null", "|", "\"\<$Failed\>\""}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "SMART"}]}], " ", "PARSING"}], "&"}], " ", 
      RowBox[{"CLUSTERING", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Processing Text & Clustering ---\>\"", "]"}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Split", " ", "each", " ", "output", " ", "by", " ", "newlines"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"StringSplit", "[", 
         RowBox[{"#", ",", "\"\<\\n\>\""}], "]"}], "&"}], "/@", 
       "allOutputs"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Strip", " ", "any", " ", "residual", " ", "numbering", " ", "prefixes", " ",
      "Gemini", " ", "may", " ", "still", " ", "add"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"StringReplace", "[", 
        RowBox[{"#", ",", 
         RowBox[{
          RowBox[{"StartOfString", "~~", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"DigitCharacter", ".."}], "~~", 
             RowBox[{"\"\<. \>\"", "|", "\"\<- \>\"", "|", "\"\<* \>\""}]}], 
            ")"}]}], "->", "\"\<\>\""}]}], "]"}], "&"}], "/@", 
      "allSentences"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Drop", " ", "blank", " ", "lines"}], ",", 
     RowBox[{"pure", " ", "numbers"}], ",", 
     RowBox[{"or", " ", "very", " ", "short", " ", "fragments"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", "allSentences", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"StringLength", "[", "#", "]"}], ">", "15"}], "&&", 
         RowBox[{"!", 
          RowBox[{"StringMatchQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"DigitCharacter", ".."}], "~~", 
             RowBox[{"\"\<.\>\"", ".."}]}]}], "]"}]}]}], "&"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "allSentences", "]"}], "<", "2"}], ",", 
      RowBox[{
       RowBox[{"clusters", "=", 
        RowBox[{"{", "allSentences", "}"}]}], ";"}], ",", 
      RowBox[{
       RowBox[{"clusters", "=", 
        RowBox[{"FindClusters", "[", 
         RowBox[{"allSentences", ",", 
          RowBox[{"FeatureExtractor", "->", "\"\<TFIDF\>\""}], ",", 
          RowBox[{"DistanceFunction", "->", "CosineDistance"}], ",", 
          RowBox[{"Method", "->", "\"\<Agglomerate\>\""}]}], "]"}]}], ";"}]}],
      "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hallucinations", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "cluster", "]"}], ">=", "2"}], ",", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"reliableEvidence", ",", 
           RowBox[{"First", "[", "cluster", "]"}]}], "]"}], ";"}], ",", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"hallucinations", ",", 
           RowBox[{"First", "[", "cluster", "]"}]}], "]"}], ";"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"cluster", ",", "clusters"}], "}"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Before deduplication: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< evidence points.\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"--", 
     RowBox[{"-", 
      RowBox[{"DEDUPLICATION", ":", 
       RowBox[{
        RowBox[{
        "remove", " ", "sentences", " ", "that", " ", "are", " ", 
         "substrings", " ", "of", " ", "longer", " ", 
         RowBox[{"ones", "--"}]}], "-"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reliableEvidence", ",", 
       RowBox[{"s1", "|->", 
        RowBox[{"NoneTrue", "[", 
         RowBox[{"reliableEvidence", ",", 
          RowBox[{"s2", "|->", 
           RowBox[{
            RowBox[{"s1", "=!=", "s2"}], "&&", 
            RowBox[{"StringContainsQ", "[", 
             RowBox[{"s2", ",", "s1"}], "]"}]}]}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<After deduplication: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< evidence points.\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "FORMAT"}]}], " ", "AS", " ", "NUMBERED", " ", "LIST", " ",
       "FOR", " ", "HCI", " ", 
      RowBox[{"READABILITY", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"numberedEvidence", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"MapIndexed", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"ToString", "[", 
           RowBox[{"#2", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
          "#1", "<>", "\"\<\\n\>\""}], "&"}], ",", "reliableEvidence"}], 
       "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"numberedHallucinations", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"MapIndexed", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"ToString", "[", 
           RowBox[{"#2", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
          "#1", "<>", "\"\<\\n\>\""}], "&"}], ",", "hallucinations"}], "]"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXPORT"}]}], " ", "TO", " ", 
      RowBox[{"VAULT", "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "exportPathReliable", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_vault.md\>\""}\
], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "exportPathHallucinations", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_\
hallucinations.md\>\""}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
     "exportPathReliable", ",", "numberedEvidence", ",", "\"\<Text\>\""}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
     "exportPathHallucinations", ",", "numberedHallucinations", 
      ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] DONE. Numbered evidence exported to \
Vault.\>\"", "]"}], ";"}]}]}]], "Input",

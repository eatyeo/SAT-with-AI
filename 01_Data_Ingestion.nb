   RowBox[{
    RowBox[{"testRes", "=", 
     RowBox[{"callGemini", "[", 
      RowBox[{"\"\<Say hello.\>\"", ",", "0.3"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[Checkmark] Connection successful.\>\"", "]"}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "5"}]}], " ", "stochastic", " ", "calls", " ", "with", " ",
      "varied", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"temperatures", "--"}], "--"}], "--"}], "--"}], "--"}], 
        "--"}], "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numCalls", "=", "5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"callTemperatures", "=", 
     RowBox[{"{", 
      RowBox[{"0.2", ",", "0.3", ",", "0.4", ",", "0.3", ",", "0.2"}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"res", ",", "temp"}], "}"}], ",", 
         RowBox[{
          RowBox[{"temp", "=", 
           RowBox[{"callTemperatures", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<--- API Call \>\"", "<>", 
            RowBox[{"ToString", "[", "i", "]"}], "<>", "\"\< of \>\"", "<>", 
            RowBox[{"ToString", "[", "numCalls", "]"}], 
            "<>", "\"\< (temp=\>\"", "<>", 
            RowBox[{"ToString", "[", "temp", "]"}], "<>", "\"\<) ---\>\""}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"callGemini", "[", 
            RowBox[{"prompt", ",", "temp"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"res", "===", "\"\<$Failed\>\""}], ",", 
            RowBox[{
             RowBox[{"Print", "[", 

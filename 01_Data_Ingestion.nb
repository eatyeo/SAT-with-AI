            "res"}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "numCalls"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{"allOutputs", ",", 
       RowBox[{"\"\<\>\"", "|", "Null", "|", "\"\<$Failed\>\""}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "Extract"}]}], " ", "and", " ", "save", " ", "central", " ",

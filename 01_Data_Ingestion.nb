    RowBox[{
    "Print", "[", "\"\<--- Extracting Central Analytical Question ---\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"extractedQuestions", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"StringSplit", "[", 
           RowBox[{"#", ",", "\"\<\\n\>\""}], "]"}], "&"}], "/@", 

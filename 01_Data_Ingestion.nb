   RowBox[{
    RowBox[{"prompt", "=", 
     RowBox[{"\"\<You are an expert intelligence analyst preparing evidence \
\>\"", "<>", "\"\<for an Analysis of Competing Hypotheses (ACH).\\n\\n\>\"", 
      "<>", "\"\<STEP 1 - Read the case below and identify the central \>\"", 
      "<>", "\"\<analytical question being asked. The analytical question \
\>\"", "<>", "\"\<determines what counts as diagnostic evidence.\\n\\n\>\"", 
      "<>", "\"\<STEP 2 - Extract only facts that are DIAGNOSTIC for \>\"", 
      "<>", "\"\<that question. A fact is diagnostic if a reasonable analyst \
\>\"", "<>", "\"\<would rate it differently depending on which hypothesis \
they \>\"", 
      "<>", "\"\<were evaluating. Facts that would receive the same rating \
under \>\"", 
      "<>", "\"\<all hypotheses are NOT diagnostic and must be \
excluded.\\n\\n\>\"", "<>", "\"\<INCLUDE facts that:\\n\>\"", 
      "<>", "\"\<- Directly support or contradict a plausible \
explanation\\n\>\"", 
      "<>", "\"\<- Describe observable outcomes, patterns, or events\\n\>\"", 
      "<>", "\"\<- Come from named sources, official findings, or documented \
incidents\\n\>\"", 
      "<>", "\"\<- Would shift an analyst's confidence in one direction over \
another\\n\\n\>\"", "<>", "\"\<EXCLUDE:\\n\>\"", 
      "<>", "\"\<- Background context with no bearing on the central question\
\\n\>\"", 
      "<>", "\"\<- Institutional or administrative details equally true under \
all hypotheses\\n\>\"", 
      "<>", "\"\<- Media coverage describing public reaction rather than \
events\\n\>\"", 
      "<>", "\"\<- Anything equally consistent with ALL competing \
explanations\\n\\n\>\"", 
      "<>", "\"\<TARGET: Extract between 12 and 25 items. Prioritize quality \
\>\"", "<>", "\"\<over quantity - 15 sharp items outperform 60 vague ones.\\n\
\\n\>\"", 
      "<>", "\"\<OUTPUT FORMAT - your response must follow this EXACT \
structure:\\n\>\"", 
      "<>", "\"\<Line 1:   CENTRAL QUESTION: [one sentence stating the \
analytical question]\\n\>\"", 
      "<>", "\"\<Line 2+:  One evidence item per line, as a plain \
sentence.\\n\\n\>\"", 
      "<>", "\"\<Do NOT use numbers, bullets, dashes, or any prefix on \
evidence lines.\\n\>\"", "<>", "\"\<Do NOT use Markdown.\\n\>\"", 
      "<>", "\"\<Do NOT add any commentary beyond what is specified above.\\n\
\\n\>\"", "<>", "\"\<Text:\\n\>\"", "<>", "docText"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 

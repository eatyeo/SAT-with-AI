Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"01", ":", 
    RowBox[{
    "Data", " ", "Ingestion", " ", "and", " ", "Semantic", " ", "Extraction", 
     " ", 
     RowBox[{"(", "EVIDENCE", ")"}]}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "==="}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "<<", "\"\</Users/Western/Desktop/ThesisCode/Core_API_Functions.wl\>\""}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<--- Connecting to Gemini ---\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"geminiService", "=", 
     RowBox[{"ServiceConnect", "[", "\"\<GoogleGemini\>\"", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "filePath", "=", "\"\</Users/Western/Desktop/ThesisCode/case.txt\>\""}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<--- Loading Case from: \>\"", "<>", "filePath", 
      "<>", "\"\< ---\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"docText", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"filePath", ",", "\"\<Text\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"NEW", " ", 
     RowBox[{"PROMPT", ":", 
      RowBox[{
      "Brutally", " ", "strict", " ", "evidence", " ", "extraction"}]}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"prompt", "=", 
     RowBox[{"\"\<Using ONLY the following text, extract all hard clinical \
evidence, facts, and symptoms. DO NOT extract hypotheses, theories, or \
explanations. Output as a plain list of sentences. Do not use Markdown \
formatting or bullet points.\\nText:\\n\>\"", "<>", "docText"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXECUTION"}]}], " ", 
      RowBox[{"LOOP", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numCalls", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "res", "}"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<--- API Call \>\"", "<>", 
            RowBox[{"ToString", "[", "i", "]"}], "<>", "\"\< of \>\"", "<>", 
            RowBox[{"ToString", "[", "numCalls", "]"}], 
            "<>", "\"\< ---\>\""}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"rateLimitedExecute", "[", 
            RowBox[{"geminiService", ",", "\"\<Chat\>\"", ",", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<Messages\>\"", "->", 
                RowBox[{"{", 
                 RowBox[{"<|", 
                  RowBox[{
                   RowBox[{"\"\<Role\>\"", "->", "\"\<user\>\""}], ",", 
                   RowBox[{"\"\<Content\>\"", "->", "prompt"}]}], "|>"}], 
                 "}"}]}], ",", 
               RowBox[{"\"\<Model\>\"", "->", "\"\<gemini-2.5-flash\>\""}], ",", 
               RowBox[{"\"\<Temperature\>\"", "->", "0.3"}]}], "|>"}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"AssociationQ", "[", "res", "]"}], "&&", 
             RowBox[{"KeyExistsQ", "[", 
              RowBox[{"res", ",", "\"\<Content\>\""}], "]"}]}], ",", 
            RowBox[{"res", "[", "\"\<Content\>\"", "]"}], ",", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<\:26a0\:fe0f Call \>\"", "<>", 
               RowBox[{"ToString", "[", "i", "]"}], 
               "<>", "\"\< failed or returned empty.\>\""}], "]"}], 
             ";", "\"\<\>\""}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "numCalls"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allOutputs", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{"allOutputs", ",", 
       RowBox[{"\"\<\>\"", "|", "Null"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "SMART"}]}], " ", "PARSING"}], "&"}], " ", 
      RowBox[{"CLUSTERING", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<--- Processing Text ---\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"TextSentences", "/@", "allOutputs"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", "allSentences", "]"}], ",", 
       RowBox[{"\"\<\>\"", "|", 
        RowBox[{"WhitespaceCharacter", ".."}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Clustering Semantically Similar Sentences ---\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "allSentences", "]"}], "<", "2"}], ",", 
      RowBox[{"clusters", "=", 
       RowBox[{"{", "allSentences", "}"}]}], ",", 
      RowBox[{
       RowBox[{"clusters", "=", 
        RowBox[{"FindClusters", "[", 
         RowBox[{"allSentences", ",", 
          RowBox[{"FeatureExtractor", "->", "\"\<TFIDF\>\""}], ",", 
          RowBox[{"DistanceFunction", "->", "CosineDistance"}], ",", 
          RowBox[{"Method", "->", "\"\<Agglomerate\>\""}]}], "]"}]}], ";"}]}],
      "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hallucinations", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "cluster", "]"}], ">", "2"}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"reliableEvidence", ",", 
          RowBox[{"First", "[", "cluster", "]"}]}], "]"}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"hallucinations", ",", 
          RowBox[{"First", "[", "cluster", "]"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"cluster", ",", "clusters"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Found \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< reliable evidence points.\>\""}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "EXPORT"}]}], " ", "TO", " ", 
      RowBox[{"VAULT", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "exportPathReliable", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_vault.md\>\""}\
], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "exportPathHallucinations", 
     "=", "\"\</Users/Western/Desktop/ThesisCode/Vault/evidence_\
hallucinations.md\>\""}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"exportPathReliable", ",", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"reliableEvidence", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"exportPathHallucinations", ",", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"Riffle", "[", 
        RowBox[{"hallucinations", ",", "\"\<\\n\>\""}], "]"}], "]"}], 
      ",", "\"\<Text\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\:2705 DONE. Pure evidence exported to Vault.\>\"", 
     "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9812039060915127`*^9, 3.981203982816805*^9}, {

       RowBox[{
        RowBox[{"StringStartsQ", "[", 
         RowBox[{"#", ",", "\"\<CENTRAL QUESTION:\>\""}], "]"}], "&"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"centralQuestion", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "extractedQuestions", "]"}], ">", "0"}], ",", 
       RowBox[{"StringTrim", "[", 
        RowBox[{"StringReplace", "[", 
         RowBox[{
          RowBox[{"First", "[", "extractedQuestions", "]"}], ",", 
          RowBox[{"\"\<CENTRAL QUESTION:\>\"", "->", "\"\<\>\""}]}], "]"}], 
        "]"}], ",", "\"\<[Could not extract central question - check prompt \
output]\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Central Question: \>\"", "<>", "centralQuestion"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<central_question.md\>\""}], ",", 
      RowBox[{"\"\<# Central Analytical Question\\n\\n\>\"", "<>", 
       "centralQuestion"}], ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"--", "Parse"}]}], " ", "and", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"cluster", "--"}], "--"}], "--"}], "--"}], "--"}],
                     "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
              "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], "--"}], 
       "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<--- Processing Text & Clustering ---\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"StringSplit", "[", 
         RowBox[{"#", ",", "\"\<\\n\>\""}], "]"}], "&"}], "/@", 
       "allOutputs"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"allSentences", ",", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"StringStartsQ", "[", 
          RowBox[{"#", ",", "\"\<CENTRAL QUESTION:\>\""}], "]"}]}], "&"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"StringReplace", "[", 
         RowBox[{"#", ",", 
          RowBox[{
           RowBox[{"StartOfString", "~~", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"DigitCharacter", ".."}], "~~", 
              RowBox[{"(", 
               RowBox[{"\"\<. \>\"", "|", "\"\<- \>\"", "|", "\"\<* \>\""}], 
               ")"}]}], ")"}]}], "->", "\"\<\>\""}]}], "]"}], "&"}], ")"}], "/@",
       "allSentences"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allSentences", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"StringTrim", "[", "allSentences", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"StringLength", "[", "#", "]"}], ">", "15"}], "&&", 
         RowBox[{"!", 
          RowBox[{"StringMatchQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"DigitCharacter", ".."}], "~~", 
             RowBox[{"\"\<.\>\"", ".."}]}]}], "]"}]}]}], "&"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "allSentences", "]"}], "<", "2"}], ",", 
      RowBox[{"clusters", "=", 
       RowBox[{"{", "allSentences", "}"}]}], ",", 
      RowBox[{"clusters", "=", 
       RowBox[{"FindClusters", "[", 
        RowBox[{"allSentences", ",", 
         RowBox[{"FeatureExtractor", "->", "\"\<TFIDF\>\""}], ",", 
         RowBox[{"DistanceFunction", "->", "CosineDistance"}], ",", 
         RowBox[{"Method", "->", "\"\<Agglomerate\>\""}]}], "]"}]}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hallucinations", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "cluster", "]"}], ">=", "2"}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"reliableEvidence", ",", 
          RowBox[{"First", "[", "cluster", "]"}]}], "]"}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"hallucinations", ",", 
          RowBox[{"First", "[", "cluster", "]"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"cluster", ",", "clusters"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Before dedup: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< items.\>\""}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Substring", " ", "dedup"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"reliableEvidence", ",", 
       RowBox[{"s1", "|->", 
        RowBox[{"NoneTrue", "[", 
         RowBox[{"reliableEvidence", ",", 
          RowBox[{"s2", "|->", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"s1", "=!=", "s2"}], "&&", 
             RowBox[{"StringContainsQ", "[", 
              RowBox[{"s2", ",", "s1"}], "]"}]}], ")"}]}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Semantic", " ", "dedup"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dedupThreshold", "=", "0.85"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"uniqueEvidence", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"AllTrue", "[", 
         RowBox[{"uniqueEvidence", ",", 
          RowBox[{"Function", "[", 
           RowBox[{"existing", ",", 
            RowBox[{
             RowBox[{"editDist", "=", 
              RowBox[{"EditDistance", "[", 
               RowBox[{
                RowBox[{"ToLowerCase", "[", "s", "]"}], ",", 
                RowBox[{"ToLowerCase", "[", "existing", "]"}]}], "]"}]}], ";",
              "\[IndentingNewLine]", 
             RowBox[{"maxLen", "=", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{"StringLength", "[", "s", "]"}], ",", 
                RowBox[{"StringLength", "[", "existing", "]"}]}], "]"}]}], ";",
              "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", 
                RowBox[{"editDist", "/", "maxLen"}]}], ")"}], "<", 
              "dedupThreshold"}]}]}], "]"}]}], "]"}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"uniqueEvidence", ",", "s"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "reliableEvidence"}], "}"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"reliableEvidence", "=", "uniqueEvidence"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<After dedup: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< items.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Hard", " ", "cap"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxEvidence", "=", "25"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "reliableEvidence", "]"}], ">", "maxEvidence"}],
       ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<[Cap] Trimming to \>\"", "<>", 
         RowBox[{"ToString", "[", "maxEvidence", "]"}], 
         "<>", "\"\< items.\>\""}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"reliableEvidence", "=", 
        RowBox[{"Take", "[", 
         RowBox[{"reliableEvidence", ",", "maxEvidence"}], "]"}]}]}]}], "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "<", "3"}], ",", 
      RowBox[{
       RowBox[{
       "Print", 
        "[", "\"\<[ERROR] Fewer than 3 evidence items survived. Check prompt \
or source text.\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Final evidence count: \>\"", "<>", 
      RowBox[{"ToString", "[", 
       RowBox[{"Length", "[", "reliableEvidence", "]"}], "]"}], 
      "<>", "\"\< items.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Format", " ", "and", " ", "export"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numberedEvidence", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"MapIndexed", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ToString", "[", 
            RowBox[{"#2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
           "#1", "<>", "\"\<\\n\>\""}], ")"}], "&"}], ",", 
        "reliableEvidence"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numberedHallucinations", "=", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"MapIndexed", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ToString", "[", 
            RowBox[{"#2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "<>", "\"\<. \>\"", "<>", 
           "#1", "<>", "\"\<\\n\>\""}], ")"}], "&"}], ",", "hallucinations"}],
        "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<evidence_vault.md\>\""}], ",", 
      "numberedEvidence", ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"$vaultDir", "<>", "\"\<evidence_hallucinations.md\>\""}], ",", 
      "numberedHallucinations", ",", "\"\<Text\>\""}], "]"}], ";"}], "\n", 
